# AESS M2M Local Bus Configuration Env File
# Port exposed on the host machine
BUS_HOST_PORT=18080

# Secret token required for WS connection. Leave empty to disable token verification in local dev.
# Example: BUS_SECRET_TOKEN=my_secret_token_123
BUS_SECRET_TOKEN=

# Max concurrent links in a single room (recommended: 2 for agycli <-> hermes)
MAX_ROOM_CLIENTS=2

# Interval in ms to dump traffic logs on the console (default: 10 seconds)
TRAFFIC_LOG_INTERVAL=10000
